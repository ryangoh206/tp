@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class AddressBook
Class WorkoutLogBook
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class WorkoutLog
Class WorkoutTime
Class Person
Class PersonComparators
Class ClientId
Class Gender
Class DateOfBirth
Class Address
Class Email
Class Name
Class Phone
Class Location
Class Plan
Class Rate
Class Height
Class Weight
Class BodyFatPercentage
Class Tag

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyAddressBook
ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs
ModelManager -left-> "1" WorkoutLogBook
UserPrefs .up.|> ReadOnlyUserPrefs

WorkoutLogBook --> "~* all" WorkoutLog
WorkoutLog --> "1" ClientId
WorkoutLog --> "1" WorkoutTime
WorkoutLog --> "1" Location

AddressBook *--> "1" UniquePersonList
UniquePersonList --> "~* all" Person
PersonComparators ..> Person : <<uses>>
Person *--> ClientId
Person *--> Name
Person *--> Phone
Person *--> Email
Person *--> Address
Person *--> "*" Tag
Person *--> Gender
Person *--> DateOfBirth
Person *--> Location
Person *--> Note
Person *--> Plan
Person *--> Rate
Person *--> Status
Person *--> Height
Person *--> Weight
Person *--> BodyFatPercentage

Person -[hidden]up--> I
UniquePersonList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email

ModelManager --> "~* filtered" Person
@enduml
